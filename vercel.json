{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/factura",
      "destination": "/agents/recharge.html?tab=factura",
      "permanent": false
    },
    {
      "source": "/factura.html",
      "destination": "/agents/recharge.html?tab=factura",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
